# Postgres
POSTGRES_USER=scpbot
POSTGRES_PASSWORD=scpbot
POSTGRES_DB=scpbot

# Embedding model served by Ollama (1024 dims for bge-m3)
SCPBOT_EMBED_MODEL=bge-m3

# Telegram (https://my.telegram.org -> API development tools)
SCPBOT_TELEGRAM_APP_ID=
SCPBOT_TELEGRAM_APP_HASH=
SCPBOT_TELEGRAM_BOT_TOKEN=

# Ingestion sources (optional; run cmd/ingest for one-shot backfills)
# GitLab docs roots as comma-separated path:repo:branch triples
SCPBOT_GITLAB_ROOTS=

# Jira (Cloud: email+token; Server: PAT). Projects comma-separated.
SCPBOT_JIRA_BASE_URL=
SCPBOT_JIRA_EMAIL=
SCPBOT_JIRA_APITOKEN=
SCPBOT_JIRA_PAT=
SCPBOT_JIRA_PROJECTS=

# Telegram user-session backfill (separate from bot token).
# Use a user session file (not bot) for history access.
SCPBOT_TELEGRAM_MONITOR_CHATS=
SCPBOT_TELEGRAM_INGEST_SESSION=
